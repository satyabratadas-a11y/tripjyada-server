PORT=4000
# local dev: mongodb://127.0.0.1:27017/task_tracker
# production: your MongoDB Atlas connection string (mongodb+srv://...)
MONGO_URI=mongodb://127.0.0.1:27017/task_tracker
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=1d
# the exact origin of the deployed Next.js client (e.g. https://your-app.vercel.app)
CLIENT_ORIGIN=http://localhost:3000
# set to "production" on the host (Render/Fly) — this also flips the auth cookie
# to SameSite=None; Secure, required for the cross-origin client/API setup
NODE_ENV=development

# optional: enables email notifications for approvals, task assignments and reviews
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# optional: enables Google account sign-in on the login page
GOOGLE_CLIENT_ID=

# used only by scripts/seedAdmin.js to bootstrap the first admin account
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# optional: enables creative/reel uploads on the Content Calendar (Cloudinary free tier works)
# without these, the upload endpoint responds with a clear "not configured" error
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# optional: enables the AI idea/caption/hook/30-day-calendar generators on the Content Calendar
# without this, AI endpoints respond with a clear "not configured" error
ANTHROPIC_API_KEY=

# optional: enables AI-powered business card scanning on the B2B card capture screen
# (free tier — get a key at https://aistudio.google.com/apikey). Without this, that
# endpoint responds with a clear "not configured" error.
GEMINI_API_KEY=

# optional: every saved B2B contact also gets appended as a row to this Google Sheet, live —
# no more manually re-downloading the Excel export. Without these three set, contact saving works
# exactly as before and this step silently no-ops. Setup:
#   1. Google Cloud Console -> create/select a project -> enable the "Google Sheets API".
#   2. IAM & Admin -> Service Accounts -> Create service account -> Keys -> Add key -> JSON.
#   3. From the downloaded JSON: GOOGLE_SERVICE_ACCOUNT_EMAIL = its "client_email",
#      GOOGLE_SERVICE_ACCOUNT_KEY = its "private_key" (keep the \n escapes as-is, paste as one line).
#   4. Open (or create) the target Google Sheet, click Share, and share it with that
#      client_email address as Editor — the service account only sees sheets explicitly shared
#      with it, same as sharing with a person.
#   5. GOOGLE_SHEETS_ID = the id in the sheet's URL: docs.google.com/spreadsheets/d/<THIS-PART>/edit
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
# optional: which tab to append to (defaults to "Sheet1" if left blank)
GOOGLE_SHEETS_TAB_NAME=
